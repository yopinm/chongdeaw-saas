/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ===== Next.js Build =====
/.next/
/out/
/build

# ===== Production =====
*.tsbuildinfo
next-env.d.ts

# ===== Environment & Secrets =====
# ครอบคลุมทุก .env variant — ห้าม commit key จริงเด็ดขาด
.env*
# uncomment บรรทัดนี้ถ้าต้องการ template สำหรับทีม
# !.env.example

# ===== Vercel =====
.vercel

# ===== Supabase Local =====
supabase/.branches
supabase/.temp

# ===== Testing =====
/coverage
/playwright-report
/test-results
.nyc_output

# ===== OS Files =====
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ===== Certificates =====
*.pem

# ===== Logs =====
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===== Editor =====
.idea/
*.swp
*.swo

# VS Code — track extensions.json ได้ แต่ไม่ track settings ส่วนตัว
.vscode/settings.json
.vscode/launch.json
"app.zip" 
